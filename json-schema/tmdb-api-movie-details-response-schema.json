            ]
          },
          "iso_639_1": {
            "type": "string",
            "examples": [
              "en"
            ]
          },
          "name": {
            "type": "string",
            "examples": [
              "English"
            ]
          }
        }
      }
    },
    "status": {
      "type": "string",
      "examples": [
        "Released"
      ]
    },
    "tagline": {
      "type": "string",
      "examples": [
        "A long time ago in a galaxy far, far away..."
      ]
    },
    "title": {
      "type": "string",
      "examples": [
        "Star Wars"
      ]
    },
    "video": {
      "type": "boolean",
      "examples": [
        false
      ],
      "default": "false"
    },
    "vote_average": {
      "type": "number",
      "examples": [
        8.2
      ],
      "default": 0
    },
    "vote_count": {
      "type": "integer",
      "examples": [
        22061
      ],
      "default": 0
    }
  }
}