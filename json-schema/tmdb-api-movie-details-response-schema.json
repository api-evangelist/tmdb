          },
          "name": {
            "type": "string",
            "examples": [
              "Lucasfilm Ltd."
            ]
          },
          "origin_country": {
            "type": "string",
            "examples": [
              "US"
            ]
          }
        }
      }
    },
    "production_countries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "iso_3166_1": {
            "type": "string",
            "examples": [
              "US"
            ]
          },
          "name": {
            "type": "string",
            "examples": [
              "United States of America"
            ]
          }
        }
      }
    },
    "release_date": {
      "type": "string",
      "examples": [
        "1977-05-25"
      ]
    },
    "revenue": {
      "type": "integer",
      "examples": [
        775398007
      ],
      "default": 0
