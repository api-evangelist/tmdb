    },
    "imdb_id": {
      "type": "string",
      "examples": [
        "tt0137523"
      ]
    },
    "wikidata_id": {},
    "facebook_id": {
      "type": "string",
      "examples": [
        "FightClub"
      ]
    },
    "instagram_id": {},
    "twitter_id": {}
  }
}