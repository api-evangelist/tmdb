              "en"
            ]
          },
          "iso_3166_1": {
            "type": "string",
            "examples": [
              "US"
            ]
          },
          "name": {
            "type": "string",
            "examples": [
              "Game Of Thrones - Season 1 Recap - Official HBO UK"
            ]
          },
          "key": {
            "type": "string",
            "examples": [
              "e0Y8KpQpW8c"
            ]
          },
          "site": {
            "type": "string",
            "examples": [
              "YouTube"
            ]
          },
          "size": {
            "type": "int32",
            "examples": [
              1080
            ],
            "default": 0
          },
          "type": {
            "type": "string",
            "examples": [
              "Recap"
            ]
          },
          "official": {
            "type": "boolean",
            "examples": [
              true
            ],
            "default": true
          },
          "published_at": {
            "type": "string",
            "examples": [
              "2015-05-19T16:31:23.000Z"
            ]
          },
          "id": {
            "type": "string",
            "examples": [
              "5ce71a920e0a265ac0cfe497"
            ]
          }
        }
      }
