{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/tmdb/refs/heads/main/json-structure/tmdb-api-movie-popular-list-response-structure.json",
  "name": "MoviePopularListResponse",
  "description": "TMDB Movies \u2014 Popular (200 payload).",
  "type": "object",
  "properties": {
    "page": {
      "type": "int32",
      "examples": [
        1
      ],
      "default": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "adult": {
            "type": "boolean",
            "examples": [
              false
            ],
            "default": true
          },
          "backdrop_path": {
            "type": "string",
            "examples": [
              "/gMJngTNfaqCSCqGD4y8lVMZXKDn.jpg"
            ]
          },
          "genre_ids": {
            "type": "array",
            "items": {
              "type": "int32",
              "examples": [
                28
              ],
              "default": 0
            }
          },
          "id": {
            "type": "int32",
            "examples": [
              640146
            ],
            "default": 0
          },
          "original_language": {
            "type": "string",
            "examples": [
              "en"
            ]
          },
          "original_title": {
            "type": "string",
            "examples": [
              "Ant-Man and the Wasp: Quantumania"
            ]
          },
          "overview": {
            "type": "string",
            "examples": [
              "Super-Hero partners Scott Lang and Hope van Dyne, along with with Hope's parents Janet van Dyne and Hank Pym, and Scott's daughter Cassie Lang, find themselves exploring the Quantum Realm, interacting with strange new creatures and embarking on an adventure that will push them beyond the limits of what they thought possible."
            ]
          },
          "popularity": {
            "type": "double",
            "examples": [
              8567.865
            ],
            "default": 0
          },
          "poster_path": {
            "type": "string",
            "examples": [
              "/ngl2FKBlU4fhbdsrtdom9LVLBXw.jpg"
            ]
          },
          "release_date": {
            "type": "string",
            "examples": [
              "2023-02-15"
            ]
          },
          "name": {
            "type": "string",
            "examples": [
              "Ant-Man and the Wasp: Quantumania"
            ]
          },
          "video": {
            "type": "boolean",
            "examples": [
              false
            ],
            "default": true
          },
          "vote_average": {
            "type": "double",
            "examples": [
              6.5
            ],
            "default": 0
          },
          "vote_count": {
            "type": "int32",
            "examples": [
              1886
            ],
            "default": 0
          }
        }
      }
    },
    "total_pages": {
      "type": "int32",
      "examples": [
        38029
      ],
      "default": 0
    },
    "total_results": {
      "type": "int32",
      "examples": [
        760569
      ],
      "default": 0
    }
  }
}