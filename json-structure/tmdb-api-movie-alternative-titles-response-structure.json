{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/tmdb/refs/heads/main/json-structure/tmdb-api-movie-alternative-titles-response-structure.json",
  "name": "MovieAlternativeTitlesResponse",
  "description": "TMDB Movies \u2014 Alternative Titles (200 payload).",
  "type": "object",
  "properties": {
    "id": {
      "type": "int32",
      "examples": [
        550
      ],
      "default": 0
    },
    "titles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "iso_3166_1": {
            "type": "string",
            "examples": [
              "RS"
            ]
          },
          "name": {
            "type": "string",
            "examples": [
              "Borila\u010dki klub"
            ]
          },
          "type": {
            "type": "string",
            "examples": [
              ""
            ]
          }
        }
      }
    }
  }
}